# ─────────────────────────────────────────────────────────────────
# NotePlate Environment Variables — copy to .env and fill in values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
FRONTEND_URL=http://localhost:3000

# ── MongoDB ───────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=NotePlate
MONGO_USERNAME=admin
MONGO_PASSWORD=change_this_password
MONGO_AUTH_SOURCE=admin

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────
JWT_ACCESS_LIFETIME=60        # minutes
JWT_REFRESH_LIFETIME=7        # days

# ── Email ─────────────────────────────────────────────────────────
# Development: use console backend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Production: use SMTP
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=NotePlate <noreply@NotePlate.app>

# ── Maps ──────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
MAPBOX_ACCESS_TOKEN=your-mapbox-token

# ── CORS ──────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── React (Frontend) ──────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000/api/v1
REACT_APP_WS_URL=ws://localhost:8000
REACT_APP_MAPBOX_TOKEN=your-mapbox-token
